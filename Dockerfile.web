# Multi-stage Dockerfile for the Next.js web app
# Uses Next.js standalone output for minimal image size
# Build context: monorepo root

# ─── Stage 1: deps ────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY .npmrc pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY package.json ./
COPY apps/community/package.json ./apps/community/package.json
COPY packages/config/package.json ./packages/config/package.json
COPY packages/db/package.json ./packages/db/package.json
COPY packages/auth/package.json ./packages/auth/package.json

RUN pnpm install --frozen-lockfile

# ─── Stage 2: builder ─────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/community/node_modules ./apps/community/node_modules

COPY .npmrc pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY packages/ ./packages/
COPY apps/community/ ./apps/community/

# NEXT_PUBLIC_* vars are baked into the client bundle at build time.
# Provide them as Docker build args in your CI/Dokploy build settings.
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ARG NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
ARG NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
ARG HETZNER_S3_PUBLIC_URL
ARG HETZNER_S3_ENDPOINT

ENV NEXT_PUBLIC_APP_URL=$NEXT_PUBLIC_APP_URL
ENV NEXT_PUBLIC_REALTIME_URL=$NEXT_PUBLIC_REALTIME_URL
ENV NEXT_PUBLIC_PORTAL_URL=$NEXT_PUBLIC_PORTAL_URL
ENV HETZNER_S3_PUBLIC_URL=$HETZNER_S3_PUBLIC_URL
ENV HETZNER_S3_ENDPOINT=$HETZNER_S3_ENDPOINT

# Skip env validation during build — server vars are injected at runtime
ENV SKIP_ENV_VALIDATION=1
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=2048"
# Dummy DB URL — postgres() is lazy and never connects during build.
# Required because the db Proxy's getPrototypeOf trap calls ensureDb(),
# which throws if DATABASE_URL is absent (triggered by Auth.js instanceof checks).
ENV DATABASE_URL=postgresql://build:build@localhost:5432/build

# Workspace packages export from dist/ — pre-compile before the app build
RUN pnpm --filter @igbo/config build && pnpm --filter @igbo/db build

RUN pnpm --filter @igbo/community build

# ─── Stage 3: runner ──────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# psql is needed for the one-shot migration container (deploy.sh runs migrations
# via `docker compose run --entrypoint sh web` before starting the app)
RUN apk add --no-cache postgresql16-client \
 && addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Standalone server (with outputFileTracingRoot=monorepo-root, Next.js 15 nests the app
# under apps/community/ inside the bundle — server.js is at apps/community/server.js)
COPY --from=builder --chown=nextjs:nodejs /app/apps/community/.next/standalone ./

# Static and public files must land beside the nested app, not at the WORKDIR root
COPY --from=builder --chown=nextjs:nodejs /app/apps/community/.next/static ./apps/community/.next/static
COPY --from=builder /app/apps/community/public ./apps/community/public

# SQL migration files — used by deploy.sh to run migrations via psql before starting the app
# Only raw SQL files are needed, not Drizzle tooling or node_modules
COPY --from=builder /app/packages/db/src/migrations ./packages/db/src/migrations

USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/api/v1/health || exit 1

CMD ["node", "apps/community/server.js"]
