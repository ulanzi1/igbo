{
  "name": "@igbo/community",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/server/seed/admin-seed.ts",
    "jobs:run": "npx tsx src/server/jobs/run-jobs.ts",
    "realtime:dev": "npx tsx --env-file=.env src/server/realtime/index.ts",
    "test:load:seed": "npx tsx scripts/seed-loadtest.ts",
    "test:load:http": "k6 run tests/load/scenarios/api-endpoints.js --out json=tests/load/results/http.json",
    "test:load:ws": "node tests/load/scenarios/ws-loadtest.mjs",
    "test:load:report": "node tests/load/lib/report.mjs",
    "test:load": "which k6 > /dev/null 2>&1 || (echo 'k6 not installed. Run: brew install k6' && exit 1) && pnpm run test:load:seed && pnpm run test:load:http && pnpm run test:load:ws && pnpm run test:load:report",
    "test:a11y:contrast": "npx tsx scripts/validate-contrast.ts"
  },
