    "@daily-co/daily-react": "^0.24.0",
    "@hookform/resolvers": "^5.2.2",
    "@igbo/config": "workspace:*",
    "@igbo/db": "workspace:*",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.45.0",
    "@serwist/next": "^9.5.6",
    "@socket.io/redis-adapter": "^7.2.0",
    "@swc/helpers": "^0.5.20",
