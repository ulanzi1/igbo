# Database
DATABASE_URL=postgresql://igbo:igbo@localhost:5432/igbo
DATABASE_POOL_SIZE=20

# PostgreSQL container (production docker-compose.prod.yml)
POSTGRES_USER=igbo
POSTGRES_PASSWORD=changeme-use-strong-password
POSTGRES_DB=igbo

# Redis
REDIS_URL=redis://localhost:6379
# Redis password (production: redis://:${REDIS_PASSWORD}@redis:6379)
REDIS_PASSWORD=changeme-use-strong-password

# Admin Bootstrap
ADMIN_EMAIL=admin@igbo.app
ADMIN_PASSWORD=changeme

# Auth.js v5
AUTH_SECRET=generate-a-secret
AUTH_URL=http://localhost:3000

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Hetzner Object Storage (S3-compatible)
HETZNER_S3_ENDPOINT=https://nbg1.your-objectstorage.com
HETZNER_S3_REGION=nbg1
HETZNER_S3_BUCKET=igbo-uploads
HETZNER_S3_ACCESS_KEY_ID=your-access-key-id
HETZNER_S3_SECRET_ACCESS_KEY=your-secret-access-key
HETZNER_S3_PUBLIC_URL=https://igbo-uploads.nbg1.your-objectstorage.com

# ClamAV virus scanner (optional — production only)
# Set to "true" to enable full virus scanning via ClamAV sidecar
ENABLE_CLAMAV=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# GDPR & Data Privacy (Story 1.13)
# Legal review required before enabling received-message inclusion in exports.
# See docs/gdpr-breach-runbook.md for tracking this decision.
INCLUDE_RECEIVED_MESSAGES_IN_EXPORT=false

# Realtime Server (Story 1.15)
REALTIME_PORT=3001
REALTIME_CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
REALTIME_INTERNAL_URL=http://localhost:3001   # use http://realtime:3001 in Docker

# Email Service (Story 1.17)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM_ADDRESS=noreply@obigbo.app
EMAIL_FROM_NAME=OBIGBO
ENABLE_EMAIL_SENDING=true

# Geocoding (Story 3.x — disabled by default, self-host Nominatim for production)
ENABLE_GEOCODING=false
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Web Push / VAPID (Epic 9 — Story 9.3)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@obigbo.app

# Sentry Error Tracking & Performance Monitoring (Story 12.3)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# LOG_LEVEL controls verbosity: debug|info|warn|error (default: info in production)
LOG_LEVEL=debug

# Prometheus metrics bearer token — protect /api/metrics endpoint (Story 12.3)
METRICS_SECRET=generate-a-secret

# Grafana admin password (docker-compose.monitoring.yml)
GRAFANA_ADMIN_PASSWORD=changeme-use-strong-password

# Backup sidecar S3 credentials (production — Story 12.2/12.4)
# Separate from app S3 credentials to allow least-privilege bucket access
BACKUP_S3_ENDPOINT=https://nbg1.your-objectstorage.com
BACKUP_S3_BUCKET=igbo-backups
BACKUP_S3_ACCESS_KEY_ID=your-backup-access-key-id
BACKUP_S3_SECRET_ACCESS_KEY=your-backup-secret-access-key

# Job Portal (P-0.4 — bidirectional navigation)
# URL of the portal app — used for "Job Portal" nav link
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
