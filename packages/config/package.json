{
  "name": "@igbo/config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./env": {
      "import": "./dist/env.js",
      "default": "./dist/env.js",
      "types": "./dist/env.d.ts"
    },
    "./redis": {
      "import": "./dist/redis.js",
      "default": "./dist/redis.js",
      "types": "./dist/redis.d.ts"
    },
    "./notifications": {
      "import": "./dist/notifications.js",
      "default": "./dist/notifications.js",
      "types": "./dist/notifications.d.ts"
    },
    "./chat": {
      "import": "./dist/chat.js",
      "default": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    },
    "./feed": {
      "import": "./dist/feed.js",
      "default": "./dist/feed.js",
      "types": "./dist/feed.d.ts"
    },
    "./points": {
      "import": "./dist/points.js",
      "default": "./dist/points.js",
      "types": "./dist/points.d.ts"
    },
    "./realtime": {
      "import": "./dist/realtime.js",
      "default": "./dist/realtime.js",
      "types": "./dist/realtime.d.ts"
    },
    "./upload": {
      "import": "./dist/upload.js",
      "default": "./dist/upload.js",
      "types": "./dist/upload.d.ts"
    },
    "./events": {
      "import": "./dist/events.js",
      "default": "./dist/events.js",
      "types": "./dist/events.d.ts"
    },
    "./match": {
      "import": "./dist/match.js",
      "default": "./dist/match.js",
      "types": "./dist/match.d.ts"
    },
    "./handler-guard": {
      "import": "./dist/handler-guard.js",
      "default": "./dist/handler-guard.js",
      "types": "./dist/handler-guard.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/env.ts src/redis.ts src/notifications.ts src/chat.ts src/feed.ts src/points.ts src/realtime.ts src/upload.ts src/events.ts src/match.ts src/handler-guard.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsup": "^8.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
