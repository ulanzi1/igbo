{
  "name": "@igbo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/*": {
      "import": "./dist/schema/*.js",
      "types": "./dist/schema/*.d.ts"
    },
    "./queries/*": {
      "import": "./dist/queries/*.js",
      "types": "./dist/queries/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@igbo/config": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
