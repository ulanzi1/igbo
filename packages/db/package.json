{
  "name": "@igbo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/*": {
      "import": "./dist/schema/*.js",
      "default": "./dist/schema/*.js",
      "types": "./dist/schema/*.d.ts"
    },
    "./queries/*": {
      "import": "./dist/queries/*.js",
      "default": "./dist/queries/*.js",
      "types": "./dist/queries/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts",
    "db:journal-sync": "npx tsx scripts/sync-journal.ts",
    "db:journal-check": "npx tsx scripts/sync-journal.ts --check"
  },
  "dependencies": {
    "@igbo/config": "workspace:*",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.9.3",
    "postgres": "^3.4.8",
    "sanitize-html": "^2.17.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/sanitize-html": "^2.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
