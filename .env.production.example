# ============================================================
# OBIGBO Production Environment Variables
# ============================================================
# Copy this file to .env on the production server:
#   cp .env.production.example .env
# Then replace ALL placeholder values with real secrets.
# NEVER commit .env with real secrets to version control.
# File permissions: chmod 600 .env
# ============================================================

# ============================================================
# DATABASE (PostgreSQL — self-hosted in Docker Compose)
# ============================================================
# For Docker Compose deployment, use the compose service hostname.
# Replace user/password/db below to match your POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB values.
DATABASE_URL=postgresql://igbo:CHANGE_ME_password@postgres:5432/igbo
DATABASE_POOL_SIZE=20

# PostgreSQL container credentials (used by postgres service in docker-compose.prod.yml)
POSTGRES_USER=igbo
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=igbo

# ============================================================
# REDIS (self-hosted in Docker Compose)
# ============================================================
# For Docker Compose deployment, use the compose service hostname with password.
# Replace the password below to match your REDIS_PASSWORD value.
REDIS_URL=redis://:CHANGE_ME_password@redis:6379
REDIS_PASSWORD=CHANGE_ME_use_a_strong_random_password

# ============================================================
# AUTHENTICATION (Auth.js v5)
# ============================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
# Production app URL (used for OAuth callbacks)
AUTH_URL=https://obigbo.app

# ============================================================
# ADMIN BOOTSTRAP
# ============================================================
ADMIN_EMAIL=admin@obigbo.app
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password_min_8_chars

# ============================================================
# NEXT.JS PUBLIC VARS (baked into JS bundle at build time)
# ============================================================
NEXT_PUBLIC_APP_URL=https://obigbo.app
NEXT_PUBLIC_REALTIME_URL=https://obigbo.app  # Cloudflare proxies /socket.io to realtime service

# ============================================================
# REALTIME SERVER (Socket.IO)
# ============================================================
REALTIME_PORT=3001
REALTIME_CORS_ORIGIN=https://obigbo.app
# Internal URL: use Docker Compose service name in production
REALTIME_INTERNAL_URL=http://realtime:3001

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=production

# ============================================================
# SESSION SECURITY TUNING
# ============================================================
MAX_SESSIONS_PER_USER=5
SESSION_TTL_SECONDS=86400
ACCOUNT_LOCKOUT_SECONDS=900
ACCOUNT_LOCKOUT_ATTEMPTS=5

# ============================================================
# HETZNER OBJECT STORAGE (S3-compatible)
# ============================================================
HETZNER_S3_ENDPOINT=https://nbg1.your-objectstorage.com
HETZNER_S3_REGION=nbg1
HETZNER_S3_BUCKET=igbo-uploads
HETZNER_S3_ACCESS_KEY_ID=CHANGE_ME_your_app_access_key_id
HETZNER_S3_SECRET_ACCESS_KEY=CHANGE_ME_your_app_secret_access_key
HETZNER_S3_PUBLIC_URL=https://igbo-uploads.nbg1.your-objectstorage.com

# ============================================================
# BACKUP SIDECAR S3 CREDENTIALS (Story 12.4)
# ============================================================
BACKUP_S3_ENDPOINT=https://nbg1.your-objectstorage.com
BACKUP_S3_BUCKET=igbo-backups
BACKUP_S3_ACCESS_KEY_ID=CHANGE_ME_your_backup_access_key_id
BACKUP_S3_SECRET_ACCESS_KEY=CHANGE_ME_your_backup_secret_access_key
# Hetzner Object Storage uses us-east-1 convention for AWS CLI compatibility
BACKUP_S3_REGION=us-east-1
# Set to false to disable WAL archiving (daily dumps still run; RPO increases to ~24h)
ENABLE_WAL_ARCHIVING=true

# ============================================================
# CLAMAV VIRUS SCANNER (optional — enable via Docker profile)
# ============================================================
# App-level scanning toggle: true = scan uploads via ClamAV
# Start ClamAV container: docker compose --profile clamav up -d
ENABLE_CLAMAV=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ============================================================
# EMAIL SERVICE (Resend)
# ============================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=CHANGE_ME_re_your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@obigbo.app
EMAIL_FROM_NAME=OBIGBO
EMAIL_SUPPORT_ADDRESS=support@obigbo.app
ENABLE_EMAIL_SENDING=true

# ============================================================
# GEOCODING (Nominatim — disabled in production by default)
# ============================================================
# For production with geocoding: self-host Nominatim or use a paid provider
ENABLE_GEOCODING=false
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ============================================================
# DAILY.CO VIDEO MEETINGS (Story 7.3)
# ============================================================
DAILY_API_KEY=CHANGE_ME_your_daily_api_key
DAILY_API_URL=https://api.daily.co/v1
# Generate a secure webhook secret: openssl rand -hex 32
DAILY_WEBHOOK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ============================================================
# WEB PUSH / VAPID (Story 9.3)
# ============================================================
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CHANGE_ME_your_vapid_public_key
VAPID_PRIVATE_KEY=CHANGE_ME_your_vapid_private_key
# Contact email for VAPID (shown to push service providers)
VAPID_CONTACT_EMAIL=admin@obigbo.app

# ============================================================
# GDPR DATA PRIVACY
# ============================================================
# See docs/gdpr-breach-runbook.md before enabling
INCLUDE_RECEIVED_MESSAGES_IN_EXPORT=false

# ============================================================
# SENTRY ERROR TRACKING & PERFORMANCE MONITORING (Story 12.3)
# ============================================================
# Get DSN from your Sentry project settings (Settings → Client Keys)
SENTRY_DSN=CHANGE_ME_your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME_your_sentry_dsn
# Set automatically in CI from git SHA — do NOT set manually on server
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_AUTH_TOKEN — CI BUILD ONLY. Set in GitHub Secrets, not on production server.
# SENTRY_ORG and SENTRY_PROJECT are build-time Sentry CLI vars — CI only, not needed at runtime.

# ============================================================
# PROMETHEUS METRICS (Story 12.3)
# ============================================================
# Protects /api/metrics endpoint from public access
# Generate: openssl rand -hex 32
METRICS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ============================================================
# LOGGING (Story 12.3)
# ============================================================
# Verbosity: debug|info|warn|error (default: info)
LOG_LEVEL=info

# ============================================================
# ALERTMANAGER (docker-compose.monitoring.yml — Story 12.3)
# ============================================================
ALERTMANAGER_SMTP_HOST=smtp.example.com
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_FROM=alerts@obigbo.app
ALERTMANAGER_SMTP_USERNAME=CHANGE_ME_smtp_username
ALERTMANAGER_SMTP_PASSWORD=CHANGE_ME_smtp_password
ALERTMANAGER_OPS_EMAIL=ops@obigbo.app
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME

# ============================================================
# GRAFANA (docker-compose.monitoring.yml — Story 12.3)
# ============================================================
# Admin password for Grafana dashboard (change admin/admin default!)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# ============================================================
# SOCIAL LOGIN (all optional — leave blank to disable)
# ============================================================
# Facebook / Meta
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# X (Twitter)
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# Instagram
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
