# Dependencies (installed fresh inside Docker)
node_modules
**/node_modules

# Next.js build cache (rebuilt inside Docker)
**/.next

# Turbo cache
**/.turbo

# Build info (regenerated by tsc --build)
**/tsconfig.tsbuildinfo

# Version control (large, not needed)
.git

# Dev/test artifacts
**/coverage
**/.vitest

# IDE
.vscode
.idea

# BMAD planning artifacts
_bmad-output
_bmad

# Misc docs
*.md
!apps/community/public/**/*.md
LICENSE
# Scripts not needed in build
scripts/backup
scripts/k8s
scripts/loadtest

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/e2e
**/playwright.config.ts
**/lighthouserc.js

# Misc
*.md
LICENSE
.prettierrc*
.eslintrc*
