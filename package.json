{
  "name": "igbo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:migrate": "pnpm --filter @igbo/db db:migrate",
    "db:journal-sync": "pnpm --filter @igbo/db db:journal-sync",
    "db:journal-check": "pnpm --filter @igbo/db db:journal-check",
    "ci-checks": "npx tsx scripts/ci-checks/index.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "2.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "apps/community/**/*.{ts,tsx,mts}": [
      "eslint --config apps/community/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "apps/portal/**/*.{ts,tsx,mts}": [
      "eslint --config apps/portal/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "packages/config/**/*.{ts,tsx,mts}": [
      "prettier --write"
    ],
    "packages/auth/**/*.{ts,mts}": [
      "prettier --write"
    ],
    "packages/db/**/*.{ts,mts}": [
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
